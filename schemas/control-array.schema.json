{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ThreatArraySchema",
    "type": "object",
    "properties": {
        "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Catalog version"
        },
        "controls": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "pattern": "^C\\.\\d{3}(\\.[1-9]\\d*)*$",
                        "description": "Hierarchical ID. Base: C.001. Refinements: C.001.1, C.001.2.1, etc."
                    },
                    "name": {
                        "type": "string",
                        "description": "Name of the control, e.g., 'Asymmetric Encryption'"
                    },
                    "description": {
                        "type": "string",
                        "description": "Detailed description of the control"
                    },
                    "source": {
                        "type": "object",
                        "description": "Source reference for the control definition",
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Name of the source"
                            },
                            "url": {
                                "type": "string",
                                "description": "URL to the source",
                                "format": "uri"
                            }
                        }
                    },
                    "notes": {
                        "type": "string",
                        "description": "Optional notes or comments for the control. e.g. rationale on protected cybersecurity properties"
                    },
                    "unitedNationsRegulation155": {
                        "type": "array",
                        "description": "List of applicable UN Regulation No. 155 mitigation categories (from Annex 5, Tables B1-B8, C1-C3)",
                        "items": {
                            "type": "string",
                            "enum": [
                                "M1",
                                "M2",
                                "M3",
                                "M4",
                                "M5",
                                "M6",
                                "M7",
                                "M8",
                                "M9",
                                "M10",
                                "M11",
                                "M12",
                                "M13",
                                "M14",
                                "M15",
                                "M16",
                                "M18",
                                "M19",
                                "M20",
                                "M21",
                                "M22",
                                "M23",
                                "M24"
                            ]
                        }
                    },
                    "attackFeasibilityReduction": {
                        "type": "object",
                        "properties": {
                            "attackPotentialReduction": {
                                "type": "object",
                                "properties": {
                                    "elapsedTime": {
                                        "$ref": "#/$defs/FeasibilityComponent"
                                    },
                                    "specialistExpertise": {
                                        "$ref": "#/$defs/FeasibilityComponent"
                                    },
                                    "knowledgeOfTheItemOrComponent": {
                                        "$ref": "#/$defs/FeasibilityComponent"
                                    },
                                    "windowOfOpportunity": {
                                        "$ref": "#/$defs/FeasibilityComponent"
                                    },
                                    "equipment": {
                                        "$ref": "#/$defs/FeasibilityComponent"
                                    }
                                },
                                "required": [
                                    "elapsedTime",
                                    "specialistExpertise",
                                    "knowledgeOfTheItemOrComponent",
                                    "windowOfOpportunity",
                                    "equipment"
                                ]
                            }
                        },
                        "required": [
                            "attackPotentialReduction"
                        ]
                    },
                    "refines": {
                        "type": "string",
                        "pattern": "^C\\.\\d{3}(\\.[1-9]\\d*)*$",
                        "description": "Must equal the parent prefix of id. Used for secondary checks."
                    },
                    "protects": {
                        "type": "array",
                        "description": "List of security properties this control protects",
                        "items": {
                            "type": "string",
                            "enum": [
                                "Confidentiality",
                                "Integrity",
                                "Availability",
                                "Authenticity",
                                "Non Repudiation"
                            ]
                        }
                    },
                    "actsOn": {
                        "type": "array",
                        "description": "System aspects the control applies to",
                        "items": {
                            "type": "string",
                            "enum": [
                                "Component",
                                "Data",
                                "Channel",
                                "Data Flow",
                                "Interface"
                            ]
                        }
                    },
                    "denies": {
                        "type": "array",
                        "description": "The specific capabilities this control prevents an attacker from exercising.",
                        "items": {
                            "$ref": "#/$defs/CapabilityNode"
                        }
                    },
                    "overriddenBy": {
                        "description": "The specific capabilities an attacker must possess to force this control to fail.",
                        "anyOf": [
                            {
                                "$ref": "#/$defs/LogicalCondition"
                            },
                            {
                                "$ref": "#/$defs/CapabilityNode"
                            }
                        ]
                    }
                },
                "required": [
                    "id",
                    "name",
                    "description",
                    "attackFeasibilityReduction",
                    "protects",
                    "actsOn"
                ]
            }
        }
    },
    "required": [
        "version",
        "controls"
    ],
    "$defs": {
        "FeasibilityComponent": {
            "type": "object",
            "properties": {
                "feasibility": {
                    "type": "string",
                    "description": "Feasibility rating code",
                    "pattern": "^(ET[0-4]|SE[0-3]|KoIC[0-3]|WoO[0-3]|Eq[0-3])$"
                },
                "rationale": {
                    "type": "string",
                    "description": "Optional rationale explaining the rating",
                    "default": ""
                }
            },
            "required": [
                "feasibility"
            ]
        },
        "CapabilityNode": {
            "type": "object",
            "properties": {
                "action": {
                    "type": "string",
                    "description": "The base attacker action or refined sub-action.",
                    "enum": [
                        "Read",
                        "Read.Extract",
                        "Read.Intercept",
                        "Modify",
                        "Modify.Write",
                        "Modify.Inject",
                        "Modify.Downgrade",
                        "Modify.Delete",
                        "Spoof",
                        "Spoof.Forge",
                        "Spoof.Replay",
                        "Disrupt",
                        "Disrupt.Exhaust",
                        "Elevate",
                        "Execute",
                        "Bypass"
                    ]
                },
                "technology": {
                    "type": "string",
                    "description": "The exact technology being acted upon, or a wildcard.",
                    "enum": [
                        "CAN",
                        "LIN",
                        "FlexRay",
                        "Ethernet",
                        "DoIP",
                        "SOME_IP",
                        "UDS",
                        "XCP",
                        "CCP",
                        "SecOC",
                        "MACsec",
                        "IPsec",
                        "J1939",
                        "MQTT",
                        "DDS",
                        "Cellular",
                        "WiFi",
                        "Bluetooth",
                        "V2X",
                        "GNSS",
                        "RF",
                        "UWB",
                        "NFC",
                        "OBD2",
                        "USB",
                        "JTAG",
                        "SWD",
                        "UART",
                        "SPI",
                        "I2C",
                        "PCIe",
                        "GMSL",
                        "Sensor",
                        "Actuator",
                        "Power",
                        "Clock",
                        "EM",
                        "Optical",
                        "PCB",
                        "SoC",
                        "MCU",
                        "GPU",
                        "NPU",
                        "HSM",
                        "TPM",
                        "TEE",
                        "TRNG",
                        "RAM",
                        "Flash",
                        "EEPROM",
                        "OTP",
                        "eFuse",
                        "Bootloader",
                        "Kernel",
                        "OS",
                        "Hypervisor",
                        "Container",
                        "Middleware",
                        "Firmware",
                        "API",
                        "App",
                        "Key",
                        "Certificate",
                        "Token",
                        "Session",
                        "Seed",
                        "Nonce",
                        "Hash",
                        "MAC",
                        "Password",
                        "Algorithm",
                        "Entropy",
                        "Calibration",
                        "Config",
                        "Model",
                        "Log",
                        "PII",
                        "*"
                    ]
                },
                "domain": {
                    "type": "string",
                    "description": "The vehicle domain, sub-domain, or wildcard.",
                    "enum": [
                        "Powertrain",
                        "Powertrain.Propulsion",
                        "Powertrain.Energy",
                        "Powertrain.BMS",
                        "Powertrain.*",
                        "Chassis",
                        "Chassis.Braking",
                        "Chassis.Steering",
                        "Chassis.Suspension",
                        "Chassis.Safety",
                        "Chassis.*",
                        "Body",
                        "Body.Access",
                        "Body.Comfort",
                        "Body.Lighting",
                        "Body.*",
                        "Infotainment",
                        "Infotainment.UI",
                        "Infotainment.OS",
                        "Infotainment.Cluster",
                        "Infotainment.*",
                        "ADAS",
                        "ADAS.Perception",
                        "ADAS.Decision",
                        "ADAS.*",
                        "Telematics",
                        "Telematics.Network",
                        "Telematics.Services",
                        "Telematics.*",
                        "Compute",
                        "Compute.Gateway",
                        "Compute.HPC",
                        "Compute.Zonal",
                        "Compute.*",
                        "Backend",
                        "Backend.OEM",
                        "Backend.ThirdParty",
                        "Backend.*",
                        "External",
                        "External.MobileApp",
                        "External.EVSE",
                        "External.DiagnosticTool",
                        "External.KeyFob",
                        "External.RSU",
                        "External.*",
                        "*"
                    ]
                }
            },
            "required": [
                "action",
                "technology",
                "domain"
            ],
            "additionalProperties": false
        },
        "LogicalCondition": {
            "type": "object",
            "properties": {
                "AND": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "$ref": "#/$defs/CapabilityNode"
                            },
                            {
                                "$ref": "#/$defs/LogicalCondition"
                            }
                        ]
                    },
                    "minItems": 1
                },
                "OR": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "$ref": "#/$defs/CapabilityNode"
                            },
                            {
                                "$ref": "#/$defs/LogicalCondition"
                            }
                        ]
                    },
                    "minItems": 1
                }
            },
            "additionalProperties": false,
            "minProperties": 1,
            "maxProperties": 1
        }
    }
}