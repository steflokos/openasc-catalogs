{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ControlArraySchema",
    "type": "object",
    "required": ["version", "controls"],
    "properties": {
        "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "controls": {
            "type": "array",
            "items": {
                "$ref": "control.schema.json"
            }
        }
    }
}