{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ThreatArraySchema",
    "type": "object",
    "required": [
        "version",
        "threats"
    ],
    "properties": {
        "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Catalog version"
        },
        "threats": {
            "type": "array",
            "items": {
                "$ref": "threat.schema.json"
            }
        }
    }
}