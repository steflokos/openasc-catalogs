{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ThreatSchema",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^T\\.\\d{2}(\\.[1-9]\\d*)*$",
            "description": "Hierarchical ID. Base: T.01. Refinements: T.01.1, T.01.2.1, etc."
        },
        "name": {
            "type": "string",
            "description": "Short name or label of the threat, e.g., 'Spoofing'"
        },
        "description": {
            "type": "string",
            "description": "Detailed description of the threat"
        },
        "metadata": {
            "type": "array",
            "description": "Curated engineering metadata. Represents the exact technologies, protocols, and hardware targeted. Used for AI context injection and UI filtering.",
            "items": {
                "type": "string",
                "enum": [
                    "CAN / CAN-FD / CAN-XL",
                    "Automotive Ethernet",
                    "LIN",
                    "FlexRay",
                    "SerDes",
                    "PCIe",
                    "SPI / I2C / I3C",
                    "UART / USART",
                    "CXPI",
                    "SENT / PSI5",
                    "Cellular",
                    "Wi-Fi",
                    "Bluetooth / BLE",
                    "UWB",
                    "NFC / RFID",
                    "GNSS",
                    "LF / RF",
                    "V2X",
                    "Satellite",
                    "mmWave",
                    "UDS",
                    "DoIP",
                    "SOME/IP",
                    "DDS",
                    "MQTT / AMQP",
                    "XCP / CCP",
                    "J1939 / FMS",
                    "ISO 15118 / OCPP",
                    "gRPC / REST",
                    "LWM2M / OMA-DM",
                    "OBD-II",
                    "JTAG / cJTAG",
                    "SWD",
                    "USB",
                    "HDMI / DisplayPort",
                    "Audio Jacks / A2B",
                    "EVSE Plug",
                    "Trailer Socket",
                    "Media Slots",
                    "Diagnostic Pads",
                    "MCU",
                    "MPU",
                    "SoC",
                    "HPC / Zonal Controller",
                    "GPU / NPU",
                    "Sensor / Actuator",
                    "Transceiver / PHY",
                    "Memory",
                    "FPGA",
                    "eFuse / OTP",
                    "RTOS",
                    "HLOS",
                    "Hypervisor",
                    "Container",
                    "Bootloader",
                    "Middleware",
                    "App / Service",
                    "Kernel / Driver",
                    "ML Model / Weights",
                    "Config / Calibration File",
                    "HSM / SHE",
                    "TEE",
                    "TPM / SE",
                    "SecOC",
                    "MACsec / IPsec",
                    "TLS / DTLS",
                    "Secure Boot",
                    "TRNG / PRNG",
                    "PUF",
                    "IDS / IPS",
                    "PKI / Certificates",
                    "Symmetric Keys",
                    "Asymmetric Keys",
                    "Hashes",
                    "MAC / HMAC / CMAC",
                    "Digital Signatures",
                    "Nonces / IVs",
                    "Passwords / PINs",
                    "Tokens / API Keys",
                    "Seeds / RoT Data"
                ]
            }
        },
        "classificationModel": {
            "type": "string",
            "enum": [
                "STRIDE",
                "MITRE ATT&CK®"
            ],
            "description": "The threat classification model this threat belongs to"
        },
        "source": {
            "type": "object",
            "description": "Source reference for the threat definition",
            "properties": {
                "name": {
                    "type": "string"
                },
                "url": {
                    "type": "string",
                    "format": "uri"
                }
            }
        },
        "notes": {
            "type": "string",
            "description": "Optional notes or comments for the threat."
        },
        "unitedNationsRegulation155": {
            "type": "array",
            "description": "List of applicable UN Regulation No. 155 threat categories",
            "items": {
                "type": "string",
                "enum": [
                    "1.1",
                    "1.2",
                    "1.3",
                    "2.1",
                    "3.1",
                    "3.2",
                    "3.3",
                    "3.4",
                    "3.5",
                    "4.1",
                    "4.2",
                    "5.1",
                    "5.2",
                    "5.3",
                    "5.4",
                    "5.5",
                    "6.1",
                    "6.2",
                    "6.3",
                    "7.1",
                    "7.2",
                    "8.1",
                    "8.2",
                    "9.1",
                    "10.1",
                    "11.1",
                    "11.2",
                    "11.3",
                    "11.4",
                    "12.1",
                    "12.2",
                    "12.3",
                    "12.4",
                    "13.1",
                    "15.1",
                    "15.2",
                    "16.1",
                    "16.2",
                    "16.3",
                    "17.1",
                    "18.1",
                    "18.2",
                    "18.3",
                    "19.1",
                    "19.2",
                    "19.3",
                    "20.1",
                    "20.2",
                    "20.3",
                    "20.4",
                    "20.5",
                    "21.1",
                    "22.2",
                    "23.1",
                    "24.1",
                    "25.1",
                    "25.2",
                    "26.1",
                    "26.2",
                    "26.3",
                    "27.1",
                    "28.1",
                    "28.2",
                    "29.1",
                    "29.2",
                    "30.1",
                    "30.2",
                    "30.3",
                    "31.1",
                    "32.1"
                ]
            }
        },
        "attackFeasibility": {
            "type": "object",
            "properties": {
                "attackPotential": {
                    "type": "object",
                    "properties": {
                        "elapsedTime": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        },
                        "specialistExpertise": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        },
                        "knowledgeOfTheItemOrComponent": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        },
                        "windowOfOpportunity": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        },
                        "equipment": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        }
                    },
                    "required": [
                        "elapsedTime",
                        "specialistExpertise",
                        "knowledgeOfTheItemOrComponent",
                        "windowOfOpportunity",
                        "equipment"
                    ]
                }
            },
            "required": [
                "attackPotential"
            ]
        },
        "refines": {
            "type": "string",
            "pattern": "^T\\.\\d{2}(\\.[1-9]\\d*)*$",
            "description": "Must equal the parent prefix of id. Used for secondary checks."
        },
        "compromises": {
            "type": "array",
            "description": "List of security properties this threat compromises",
            "items": {
                "type": "string",
                "enum": [
                    "Confidentiality",
                    "Integrity",
                    "Availability",
                    "Authenticity",
                    "Non Repudiation"
                ]
            }
        },
        "requires": {
            "description": "The AND/OR capabilities required to execute this threat.",
            "anyOf": [
                {
                    "$ref": "#/$defs/LogicalCondition"
                },
                {
                    "$ref": "#/$defs/CapabilityNode"
                }
            ]
        },
        "grants": {
            "type": "array",
            "description": "The new capabilities this threat provides to the attacker upon success.",
            "items": {
                "$ref": "#/$defs/CapabilityNode"
            }
        }
    },
    "required": [
        "id",
        "name",
        "description",
        "classificationModel",
        "attackFeasibility",
        "compromises"
    ],
    "$defs": {
        "FeasibilityComponent": {
            "type": "object",
            "properties": {
                "feasibility": {
                    "type": "string",
                    "pattern": "^(ET[0-4]|SE[0-3]|KoIC[0-3]|WoO[0-3]|Eq[0-3])$"
                },
                "rationale": {
                    "type": "string",
                    "default": ""
                }
            },
            "required": [
                "feasibility"
            ]
        },
        "CapabilityNode": {
            "type": "object",
            "properties": {
                "action": {
                    "type": "string",
                    "description": "The MECE-aligned attacker action.",
                    "enum": [
                        "Extract",
                        "Intercept",
                        "Modify",
                        "Inject",
                        "Disrupt",
                        "Execute",
                        "Elevate",
                        "Fault"
                    ]
                },
                "assetClass": {
                    "type": "string",
                    "description": "The MECE-aligned target class.",
                    "enum": [
                        "Compute",
                        "Memory",
                        "Peripheral",
                        "Network",
                        "Interface",
                        "Executable",
                        "Data",
                        "Crypto"
                    ]
                },
                "domain": {
                    "type": "string",
                    "description": "The vehicle primary domain.",
                    "enum": [
                        "Powertrain",
                        "Chassis",
                        "Body",
                        "Infotainment",
                        "ADAS",
                        "Telematics",
                        "External",
                        "Backend"
                    ]
                }
            },
            "required": [
                "action",
                "assetClass",
                "domain"
            ],
            "additionalProperties": false
        },
        "LogicalCondition": {
            "type": "object",
            "properties": {
                "AND": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "$ref": "#/$defs/CapabilityNode"
                            },
                            {
                                "$ref": "#/$defs/LogicalCondition"
                            }
                        ]
                    },
                    "minItems": 1
                },
                "OR": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "$ref": "#/$defs/CapabilityNode"
                            },
                            {
                                "$ref": "#/$defs/LogicalCondition"
                            }
                        ]
                    },
                    "minItems": 1
                }
            },
            "additionalProperties": false,
            "minProperties": 1,
            "maxProperties": 1
        }
    }
}