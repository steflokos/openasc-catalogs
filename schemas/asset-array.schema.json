{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AssetArraySchema",
    "type": "object",
    "required": [
        "version",
        "assets"
    ],
    "properties": {
        "version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$",
            "description": "Catalog version"
        },
        "assets": {
            "type": "array",
            "items": {
                "$ref": "asset.schema.json"
            }
        }
    }
}