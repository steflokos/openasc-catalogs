{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "AssetSchema",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^A\\.\\d{3}(\\.[1-9]\\d*)*$",
            "description": "Hierarchical ID. Base: A.001. Refinements: A.001.1, A.001.2.1, etc."
        },
        "name": {
            "type": "string",
            "description": "Name of the asset, e.g., 'BMS Master Firmware'"
        },
        "description": {
            "type": "string",
            "description": "Detailed description of the asset and its function within the system"
        },
        "class": {
            "type": "string",
            "description": "The functional security class of this asset. Maps symmetrically to the Attack Graph Asset Class.",
            "enum": [
                "Compute",
                "Memory",
                "Peripheral",
                "Network",
                "Interface",
                "Executable",
                "Data",
                "Crypto"
            ]
        },
        "domain": {
            "type": "string",
            "description": "The primary vehicle architectural domain.",
            "enum": [
                "Powertrain",
                "Chassis",
                "Body",
                "Infotainment",
                "ADAS",
                "Telematics",
                "External",
                "Backend"
            ]
        },
        "partOf": {
            "type": "string",
            "pattern": "^A\\.\\d{3}(\\.[1-9]\\d*)*$",
            "description": "Reference to a parent asset that this asset belongs to or is hosted on. Used for secondary checks."
        },
        "notes": {
            "type": "string",
            "description": "Optional notes, comments, or references for the asset"
        },
        "cybersecurityProperties": {
            "type": "array",
            "description": "The CIANA security properties that must be protected for this asset",
            "items": {
                "type": "string",
                "enum": [
                    "Confidentiality",
                    "Integrity",
                    "Availability",
                    "Authenticity",
                    "Non Repudiation"
                ]
            },
            "minItems": 1,
            "uniqueItems": true
        },
        "impact": {
            "type": "object",
            "description": "Impact evaluation if the asset is compromised, categorized by stakeholder perspective",
            "properties": {
                "oem": {
                    "$ref": "#/$defs/StakeholderImpact"
                },
                "roadUser": {
                    "$ref": "#/$defs/StakeholderImpact"
                },
                "thirdPartySupplier": {
                    "$ref": "#/$defs/StakeholderImpact"
                }
            },
            "required": [
                "oem",
                "roadUser"
            ]
        }
    },
    "required": [
        "id",
        "name",
        "description",
        "class",
        "domain",
        "cybersecurityProperties",
        "impact"
    ],
    "$defs": {
        "StakeholderImpact": {
            "type": "object",
            "properties": {
                "safety": {
                    "$ref": "#/$defs/ImpactComponent"
                },
                "financial": {
                    "$ref": "#/$defs/ImpactComponent"
                },
                "operational": {
                    "$ref": "#/$defs/ImpactComponent"
                },
                "privacy": {
                    "$ref": "#/$defs/ImpactComponent"
                }
            },
            "required": [
                "safety",
                "financial",
                "operational",
                "privacy"
            ],
            "additionalProperties": false
        },
        "ImpactComponent": {
            "type": "object",
            "properties": {
                "level": {
                    "$ref": "#/$defs/ImpactLevel"
                },
                "rationale": {
                    "type": "string",
                    "description": "Optional explanation for why this specific impact rating was chosen",
                    "default": ""
                }
            },
            "required": [
                "level"
            ],
            "additionalProperties": false
        },
        "ImpactLevel": {
            "type": "string",
            "enum": [
                "Severe",
                "Major",
                "Moderate",
                "Negligible",
                "None"
            ],
            "description": "Standard ISO 21434 impact rating scale"
        }
    }
}