{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ControlSchema",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^C\\.\\d{2}(\\.[1-9]\\d*)*$",
            "description": "Hierarchical ID. Base: C.01. Refinements: C.01.1, C.01.2.1, etc."
        },
        "name": {
            "type": "string",
            "description": "Name of the control, e.g., 'Asymmetric Encryption'"
        },
        "description": {
            "type": "string",
            "description": "Detailed description of the control"
        },
        "metadata": {
            "type": "array",
            "description": "Curated engineering metadata. Represents the exact technologies, protocols, and mechanisms this control secures. Used for AI context injection and UI filtering.",
            "items": {
                "type": "string",
                "enum": [
                    "CAN / CAN-FD / CAN-XL",
                    "Automotive Ethernet",
                    "LIN",
                    "FlexRay",
                    "SerDes",
                    "PCIe",
                    "SPI / I2C / I3C",
                    "UART / USART",
                    "CXPI",
                    "SENT / PSI5",
                    "Cellular",
                    "Wi-Fi",
                    "Bluetooth / BLE",
                    "UWB",
                    "NFC / RFID",
                    "GNSS",
                    "LF / RF",
                    "V2X",
                    "Satellite",
                    "mmWave",
                    "UDS",
                    "DoIP",
                    "SOME/IP",
                    "DDS",
                    "MQTT / AMQP",
                    "XCP / CCP",
                    "J1939 / FMS",
                    "ISO 15118 / OCPP",
                    "gRPC / REST",
                    "LWM2M / OMA-DM",
                    "OBD-II",
                    "JTAG / cJTAG",
                    "SWD",
                    "USB",
                    "HDMI / DisplayPort",
                    "Audio Jacks / A2B",
                    "EVSE Plug",
                    "Trailer Socket",
                    "Media Slots",
                    "Diagnostic Pads",
                    "MCU",
                    "MPU",
                    "SoC",
                    "HPC / Zonal Controller",
                    "GPU / NPU",
                    "Sensor / Actuator",
                    "Transceiver / PHY",
                    "Memory",
                    "FPGA",
                    "eFuse / OTP",
                    "RTOS",
                    "HLOS",
                    "Hypervisor",
                    "Container",
                    "Bootloader",
                    "Middleware",
                    "App / Service",
                    "Kernel / Driver",
                    "ML Model / Weights",
                    "Config / Calibration File",
                    "HSM / SHE",
                    "TEE",
                    "TPM / SE",
                    "SecOC",
                    "MACsec / IPsec",
                    "TLS / DTLS",
                    "Secure Boot",
                    "TRNG / PRNG",
                    "PUF",
                    "IDS / IPS",
                    "PKI / Certificates",
                    "Symmetric Keys",
                    "Asymmetric Keys",
                    "Hashes",
                    "MAC / HMAC / CMAC",
                    "Digital Signatures",
                    "Nonces / IVs",
                    "Passwords / PINs",
                    "Tokens / API Keys",
                    "Seeds / RoT Data"
                ]
            }
        },
        "source": {
            "type": "object",
            "description": "Source reference for the control definition",
            "properties": {
                "name": {
                    "type": "string"
                },
                "url": {
                    "type": "string",
                    "format": "uri"
                }
            }
        },
        "notes": {
            "type": "string",
            "description": "Optional notes or comments for the control."
        },
        "unitedNationsRegulation155": {
            "type": "array",
            "description": "List of applicable UN Regulation No. 155 mitigation categories",
            "items": {
                "type": "string",
                "enum": [
                    "M1",
                    "M2",
                    "M3",
                    "M4",
                    "M5",
                    "M6",
                    "M7",
                    "M8",
                    "M9",
                    "M10",
                    "M11",
                    "M12",
                    "M13",
                    "M14",
                    "M15",
                    "M16",
                    "M18",
                    "M19",
                    "M20",
                    "M21",
                    "M22",
                    "M23",
                    "M24"
                ]
            }
        },
        "attackFeasibilityReduction": {
            "type": "object",
            "properties": {
                "attackPotentialReduction": {
                    "type": "object",
                    "properties": {
                        "elapsedTime": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        },
                        "specialistExpertise": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        },
                        "knowledgeOfTheItemOrComponent": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        },
                        "windowOfOpportunity": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        },
                        "equipment": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        }
                    },
                    "required": [
                        "elapsedTime",
                        "specialistExpertise",
                        "knowledgeOfTheItemOrComponent",
                        "windowOfOpportunity",
                        "equipment"
                    ]
                }
            },
            "required": [
                "attackPotentialReduction"
            ]
        },
        "refines": {
            "type": "string",
            "pattern": "^C\\.\\d{2}(\\.[1-9]\\d*)*$",
            "description": "Must equal the parent prefix of id. Used for secondary checks."
        },
        "protects": {
            "type": "array",
            "description": "List of security properties this control protects",
            "items": {
                "type": "string",
                "enum": [
                    "Confidentiality",
                    "Integrity",
                    "Availability",
                    "Authenticity",
                    "Non Repudiation"
                ]
            }
        },
        "denies": {
            "type": "array",
            "description": "The specific capabilities this control prevents an attacker from exercising.",
            "items": {
                "$ref": "#/$defs/CapabilityNode"
            }
        },
        "overriddenBy": {
            "description": "The specific capabilities an attacker must possess to force this control to fail.",
            "anyOf": [
                {
                    "$ref": "#/$defs/LogicalCondition"
                },
                {
                    "$ref": "#/$defs/CapabilityNode"
                }
            ]
        }
    },
    "required": [
        "id",
        "name",
        "description",
        "attackFeasibilityReduction",
        "protects"
    ],
    "$defs": {
        "FeasibilityComponent": {
            "type": "object",
            "properties": {
                "feasibility": {
                    "type": "string",
                    "pattern": "^(ET[0-4]|SE[0-3]|KoIC[0-3]|WoO[0-3]|Eq[0-3])$"
                },
                "rationale": {
                    "type": "string",
                    "default": ""
                }
            },
            "required": [
                "feasibility"
            ]
        },
        "CapabilityNode": {
            "type": "object",
            "properties": {
                "action": {
                    "type": "string",
                    "description": "The MECE-aligned attacker action.",
                    "enum": [
                        "Extract",
                        "Intercept",
                        "Modify",
                        "Inject",
                        "Disrupt",
                        "Execute",
                        "Elevate",
                        "Fault"
                    ]
                },
                "assetClass": {
                    "type": "string",
                    "description": "The MECE-aligned target class.",
                    "enum": [
                        "Compute",
                        "Memory",
                        "Peripheral",
                        "Network",
                        "Interface",
                        "Executable",
                        "Data",
                        "Crypto"
                    ]
                },
                "domain": {
                    "type": "string",
                    "description": "The vehicle primary domain.",
                    "enum": [
                        "Powertrain",
                        "Chassis",
                        "Body",
                        "Infotainment",
                        "ADAS",
                        "Telematics",
                        "External",
                        "Backend"
                    ]
                }
            },
            "required": [
                "action",
                "assetClass",
                "domain"
            ],
            "additionalProperties": false
        },
        "LogicalCondition": {
            "type": "object",
            "properties": {
                "AND": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "$ref": "#/$defs/CapabilityNode"
                            },
                            {
                                "$ref": "#/$defs/LogicalCondition"
                            }
                        ]
                    },
                    "minItems": 1
                },
                "OR": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "$ref": "#/$defs/CapabilityNode"
                            },
                            {
                                "$ref": "#/$defs/LogicalCondition"
                            }
                        ]
                    },
                    "minItems": 1
                }
            },
            "additionalProperties": false,
            "minProperties": 1,
            "maxProperties": 1
        }
    }
}