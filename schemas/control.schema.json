{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ControlSchema",
    "type": "object",
    "properties": {
        "id": {
            "type": "string",
            "pattern": "^C\\.\\d{2}(\\.[1-9]\\d*)*$",
            "description": "Hierarchical ID. Base: C.01. Refinements: C.01.1, C.01.2.1, etc."
        },
        "name": {
            "type": "string",
            "description": "Name of the control, e.g., 'Asymmetric Encryption'"
        },
        "description": {
            "type": "string",
            "description": "Detailed description of the control"
        },
        "source": {
            "type": "object",
            "description": "Source reference for the control definition",
            "properties": {
                "name": {
                    "type": "string"
                },
                "url": {
                    "type": "string",
                    "format": "uri"
                }
            }
        },
        "notes": {
            "type": "string",
            "description": "Optional notes or comments for the control."
        },
        "unitedNationsRegulation155": {
            "type": "array",
            "description": "List of applicable UN Regulation No. 155 mitigation categories",
            "items": {
                "type": "string",
                "enum": [
                    "M1",
                    "M2",
                    "M3",
                    "M4",
                    "M5",
                    "M6",
                    "M7",
                    "M8",
                    "M9",
                    "M10",
                    "M11",
                    "M12",
                    "M13",
                    "M14",
                    "M15",
                    "M16",
                    "M18",
                    "M19",
                    "M20",
                    "M21",
                    "M22",
                    "M23",
                    "M24"
                ]
            }
        },
        "attackFeasibilityReduction": {
            "type": "object",
            "properties": {
                "attackPotentialReduction": {
                    "type": "object",
                    "properties": {
                        "elapsedTime": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        },
                        "specialistExpertise": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        },
                        "knowledgeOfTheItemOrComponent": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        },
                        "windowOfOpportunity": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        },
                        "equipment": {
                            "$ref": "#/$defs/FeasibilityComponent"
                        }
                    },
                    "required": [
                        "elapsedTime",
                        "specialistExpertise",
                        "knowledgeOfTheItemOrComponent",
                        "windowOfOpportunity",
                        "equipment"
                    ]
                }
            },
            "required": [
                "attackPotentialReduction"
            ]
        },
        "refines": {
            "type": "string",
            "pattern": "^C\\.\\d{2}(\\.[1-9]\\d*)*$",
            "description": "Must equal the parent prefix of id. Used for secondary checks."
        },
        "protects": {
            "type": "array",
            "description": "List of security properties this control protects",
            "items": {
                "type": "string",
                "enum": [
                    "Confidentiality",
                    "Integrity",
                    "Availability",
                    "Authenticity",
                    "Non Repudiation"
                ]
            }
        },
        "denies": {
            "type": "array",
            "description": "The specific capabilities this control prevents an attacker from exercising.",
            "items": {
                "$ref": "#/$defs/CapabilityNode"
            }
        },
        "overriddenBy": {
            "description": "The specific capabilities an attacker must possess to force this control to fail.",
            "anyOf": [
                {
                    "$ref": "#/$defs/LogicalCondition"
                },
                {
                    "$ref": "#/$defs/CapabilityNode"
                }
            ]
        }
    },
    "required": [
        "id",
        "name",
        "description",
        "attackFeasibilityReduction",
        "protects"
    ],
    "$defs": {
        "FeasibilityComponent": {
            "type": "object",
            "properties": {
                "feasibility": {
                    "type": "string",
                    "pattern": "^(ET[0-4]|SE[0-3]|KoIC[0-3]|WoO[0-3]|Eq[0-3])$"
                },
                "rationale": {
                    "type": "string",
                    "default": ""
                }
            },
            "required": [
                "feasibility"
            ]
        },
        "CapabilityNode": {
            "type": "object",
            "properties": {
                "action": {
                    "type": "string",
                    "description": "The MECE-aligned attacker action.",
                    "enum": [
                        "Extract",
                        "Intercept",
                        "Modify",
                        "Inject",
                        "Disrupt",
                        "Execute",
                        "Elevate",
                        "Fault"
                    ]
                },
                "assetClass": {
                    "type": "string",
                    "description": "The MECE-aligned target class.",
                    "enum": [
                        "Compute",
                        "Memory",
                        "Peripheral",
                        "Network",
                        "Interface",
                        "Executable",
                        "Data",
                        "Crypto"
                    ]
                },
                "domain": {
                    "type": "string",
                    "description": "The vehicle primary domain.",
                    "enum": [
                        "Powertrain",
                        "Chassis",
                        "Body",
                        "Infotainment",
                        "ADAS",
                        "Telematics",
                        "External",
                        "Backend"
                    ]
                }
            },
            "required": [
                "action",
                "assetClass",
                "domain"
            ],
            "additionalProperties": false
        },
        "LogicalCondition": {
            "type": "object",
            "properties": {
                "AND": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "$ref": "#/$defs/CapabilityNode"
                            },
                            {
                                "$ref": "#/$defs/LogicalCondition"
                            }
                        ]
                    },
                    "minItems": 1
                },
                "OR": {
                    "type": "array",
                    "items": {
                        "anyOf": [
                            {
                                "$ref": "#/$defs/CapabilityNode"
                            },
                            {
                                "$ref": "#/$defs/LogicalCondition"
                            }
                        ]
                    },
                    "minItems": 1
                }
            },
            "additionalProperties": false,
            "minProperties": 1,
            "maxProperties": 1
        }
    }
}